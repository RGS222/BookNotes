</main>
<footer>Copyright © <%= new Date().getFullYear() %>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>
</body>

<% if (locals.message) { %>
    <!--show message dialog at page load-->
    <script>
        document.addEventListener('hide.bs.modal', function (event) {
            // Remove the focus from the active element
            console.log("hide.bs.modal")
            if (document.activeElement) {
                document.activeElement.blur();
            }
        });
        const myModal = new bootstrap.Modal(document.getElementById('exampleModalCenter'));
        myModal.show();
    </script>
<% } %>

<% if (locals.username && locals.password) { %>
    <!--store username and password after validation-->
    <script>
        localStorage.setItem("username", "<%= username %>");
        localStorage.setItem("password", "<%= password %>");
    </script>
<% } %>
</html>